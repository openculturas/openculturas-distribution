{% extends "@openculturas_base/node/node--full.html.twig" %}

{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'view-mode-' ~ view_mode|clean_class,
    content.field_layout_switcher.0.value ? content.field_layout_switcher.0.value|clean_class,
  ]
%}

{% block content_wrapper %}
  {% set wrapper_tag = 'article' %}
  <{{ wrapper_tag }}{{ attributes.addClass(classes) }}>
  {{ parent() }}
  </{{ wrapper_tag }}>
{% endblock %}
